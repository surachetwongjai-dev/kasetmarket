# ================================================
# KasetMarket — ตัวอย่าง environment variables
# คัดลอกไฟล์นี้เป็น .env แล้วเติมค่าจริง (ห้าม commit .env)
# ================================================

# --- Database (ต้องมีก่อนเริ่ม M2) ---
# เลือกใช้ผู้ให้บริการเดียว (Neon แนะนำ) แล้วใส่ค่าจริงแทนที่ 2 บรรทัดด้านล่างนี้ที่เดียว
# ห้ามมีตัวแปรชื่อซ้ำกันหลายบรรทัดใน .env — บรรทัดหลังสุดจะทับบรรทัดก่อนหน้าเงียบๆ
#
# ถ้าใช้ Neon: Dashboard → Connection Details → Connection string
#   ติ๊ก/ปิด toggle "Pooled connection" เพื่อสลับดู 2 แบบ
#   DATABASE_URL = แบบ Pooled (host มี "-pooler") ใช้ตอนแอปรัน
#   DIRECT_URL   = แบบ Direct (host ไม่มี "-pooler") ใช้ตอน prisma migrate
#
# ถ้าใช้ Supabase แทน: Settings → Database → Connection string
#   DATABASE_URL = Session pooler (port 5432)
#   DIRECT_URL   = Direct connection (ถ้าต่อไม่ติดให้ใช้ค่าเดียวกับ pooler)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST.ap-southeast-1.aws.neon.tech/neondb?sslmode=require"

# --- Auth (จำเป็นตั้งแต่ M3) ---
# สร้าง secret: npx auth secret  หรือ  openssl rand -base64 32
AUTH_SECRET=""
# LINE Developers Console → LINE Login channel → callback: http://localhost:3000/api/auth/callback/line
LINE_CLIENT_ID=""
LINE_CLIENT_SECRET=""
# Google Cloud Console → APIs & Services → Credentials → callback: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Cloudflare R2 (M4) ---
# ยังไม่ใส่ก็รันได้: ระบบจะเก็บรูปลงโฟลเดอร์ .uploads/ ในเครื่องแทน (dev เท่านั้น)
# ใส่ครบทั้ง 5 ค่าเมื่อไหร่ ระบบสลับไปใช้ R2 ให้อัตโนมัติ ไม่ต้องแก้โค้ด
# R2 Dashboard → Manage R2 API Tokens → สร้าง token แบบ Object Read & Write
# R2_ACCOUNT_ID=""
# R2_ACCESS_KEY_ID=""
# R2_SECRET_ACCESS_KEY=""
# R2_BUCKET="kasetmarket-images"
# R2_PUBLIC_BASE_URL=""   # public r2.dev URL ของ bucket หรือ custom domain (ไม่มี / ท้าย)

# --- Site (M9) ---
# URL หลักของเว็บ — ใช้สร้าง canonical/sitemap/OG (production ต้องเป็นโดเมนจริง)
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# ลิงก์ช่อง YouTube — ถ้าไม่ตั้ง แถบ YouTube บนหน้าแรกจะซ่อนอัตโนมัติ
# NEXT_PUBLIC_YOUTUBE_URL=""

# หมายเหตุ: `npm run build` จะรัน scripts/check-env.ts ตรวจความครบก่อนเสมอ
# บน Vercel (หรือ CHECK_ENV_STRICT=1) จะบังคับครบชุด production: LINE/Google, R2 ทั้ง 5, SITE_URL โดเมนจริง
